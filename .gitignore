# ==============================================================================
# File: .gitignore
# Purpose:
#   Ignore local runtime state, secrets, build outputs and editor files.
# ==============================================================================

# Local environment and secrets
.env
*.env
.sops.yaml

# Generated state
state/
state1/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
terraform.tfvars
*.auto.tfvars
.terraform.lock.hcl

# Ansible
*.retry

# Packer
packer_cache/

# OS/editor
.DS_Store
.idea/
.vscode/
*.swp

# Binaries and logs
*.exe
*.dll
*.so
*.dylib
*.log
*.out
coverage.*

# Patch leftovers
*.orig
*.rej
*.patch
*.diff

# Python cache
__pycache__/
*.pyc


# Generated Terraform secret variables
terraform/proxmox/community-scripts-lxc/secrets.auto.tfvars.json
terraform/proxmox/community-scripts-lxc/.terraform.lock.hcl

# Ansible Galaxy downloaded roles
ansible/roles/marvinpinto.docker-plex/